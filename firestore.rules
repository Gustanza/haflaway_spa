rules_version = '2';

// TEMPORARY ROLLBACK — reverted to fully open for an active outage
// investigation. The hardened version (organizations/users/clickpesaPayments
// scoped rules) is saved and will be redeployed once we confirm whether this
// was actually the cause.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write;
    }
  }
}
